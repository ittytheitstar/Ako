{
  "$schema": "https://example.invalid/ako/spec/db.schema.json",
  "db": "postgresql",
  "tenancy": "single-db, tenant_id in every row; optional schema-per-tenant later",
  "uuid": "uuidv7 (generated in app) or gen_random_uuid()",
  "tables": [
    "tenants",
    "users",
    "user_identities",
    "roles",
    "permissions",
    "role_permissions",
    "user_roles",
    "cohorts",
    "cohort_members",
    "courses",
    "course_sections",
    "course_modules",
    "content_items",
    "enrolments",
    "assignments",
    "assignment_submissions",
    "assignment_feedback",
    "quizzes",
    "quiz_questions",
    "quiz_attempts",
    "quiz_answers",
    "grade_items",
    "grades",
    "forums",
    "forum_threads",
    "forum_posts",
    "post_reactions",
    "conversations",
    "conversation_members",
    "messages",
    "message_reactions",
    "notifications",
    "files",
    "file_refs",
    "lti_registrations",
    "lti_deployments",
    "lti_resource_links",
    "lti_grades",
    "scim_resources",
    "scim_etags",
    "audit_log",
    "outbox_events",
    "webhooks",
    "webhook_deliveries"
  ],
  "partitioned": [
    "audit_log",
    "outbox_events"
  ],
  "indexes": [
    "tenant scoping",
    "course lookups",
    "search vectors (optional)"
  ],
  "constraints": [
    "FKs",
    "soft-delete patterns",
    "row-level security optional"
  ]
}